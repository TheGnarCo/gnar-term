{
  "name": "gnar-term",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "description": "Terminal workspace manager for AI coding agents",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "vite": "vite",
    "vite:build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "check": "svelte-check --tsconfig ./tsconfig.json --threshold error",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run lint && npm run typecheck && npm run check && npm test && npm run vite:build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@embedpdf/snippet": "^2.12.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "2.7.0",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "@xterm/addon-fit": "0.12.0-beta.196",
    "@xterm/addon-search": "0.17.0-beta.196",
    "@xterm/addon-web-links": "0.13.0-beta.196",
    "@xterm/addon-webgl": "0.20.0-beta.195",
    "@xterm/xterm": "6.1.0-beta.196",
    "dompurify": "^3.3.3",
    "github-markdown-css": "^5.8.1",
    "marked": "^15.0.0",
    "pdfjs-dist": "^4.10.38",
    "svelte": "^5.55.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/dompurify": "^3.0.5",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "10.2.0",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-svelte": "3.17.0",
    "jsdom": "^27.0.1",
    "lefthook": "2.1.5",
    "prettier": "3.8.2",
    "prettier-plugin-svelte": "3.5.1",
    "svelte-check": "4.4.6",
    "svelte-eslint-parser": "1.6.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.8",
    "vitest": "^3.2.4"
  }
}
