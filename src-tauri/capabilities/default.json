{
  "identifier": "default",
  "description": "Default capability for ClawTab",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:allow-start-dragging",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "core:app:default",
    {
      "identifier": "asset-protocol",
      "allow": [{ "path": "**" }]
    }
  ]
}
