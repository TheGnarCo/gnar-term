{
  "$schema": "https://raw.githubusercontent.com/nicegist/tauri-v2-schema/main/tauri.conf.json",
  "productName": "GnarTerm",
  "version": "0.3.1",
  "identifier": "com.thegnar.gnar-term",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run vite",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "title": "GnarTerm",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: blob: data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; media-src 'self' blob:; frame-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDIR/**"]
      }
    },
    "enableGTKAppId": false,
    "withGlobalTauri": false
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/thegnarco/gnar-term/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "entitlements.plist"
    }
  }
}
